#!/usr/bin/env bash
set -euo pipefail

VERSION="0.1.0"
AI_INST_DIR="${AI_INST_DIR:-$HOME/.ai-instructions}"
MODULES_DIR="$AI_INST_DIR/modules"
SKILLS_DIR="$AI_INST_DIR/skills"
MIGRATIONS_DIR="$AI_INST_DIR/migrations"
AI_MODULES_FILE=".ai-modules"
AI_MIGRATIONS_STATE=".ai-migrations-state"
LOCAL_INSTRUCTIONS="instructions.local.md"
DEFAULT_TARGET="CLAUDE.md"

# ─── Helpers ──────────────────────────────────────────────────────────────────

die() { echo "error: $*" >&2; exit 1; }
info() { echo ":: $*"; }

ensure_repo() {
  [[ -d "$AI_INST_DIR/.git" ]] || die "Rules repo not found at $AI_INST_DIR. Run: ai-inst repo init"
}

ensure_project() {
  [[ -f "$AI_MODULES_FILE" ]] || die "No $AI_MODULES_FILE found. Run: ai-inst project init"
}

module_path() { echo "$MODULES_DIR/$1.md"; }

module_exists() { [[ -f "$(module_path "$1")" ]]; }

skill_path() { echo "$SKILLS_DIR/$1"; }

skill_exists() { [[ -d "$SKILLS_DIR/$1" && -f "$SKILLS_DIR/$1/SKILL.md" ]]; }

skill_description() {
  local skill_md="$SKILLS_DIR/$1/SKILL.md"
  [[ -f "$skill_md" ]] || return
  sed -n '/^---$/,/^---$/{ /^description:/{ s/^description: *//; s/^ *"//; s/" *$//; p; q; } }' "$skill_md"
}

# Parse .ai-modules → targets, module list, and skills list
parse_ai_modules() {
  local targets=()
  local modules=()
  local skills=()
  local in_skills=0
  while IFS= read -r line; do
    line="${line%%#*}"
    line="$(echo "$line" | xargs)" # trim
    [[ -z "$line" ]] && continue
    if [[ "$line" == "[skills]" ]]; then
      in_skills=1
      continue
    fi
    if [[ "$line" == targets:* ]]; then
      read -ra targets <<< "${line#targets:}"
    elif [[ "$in_skills" -eq 1 ]]; then
      skills+=("$line")
    else
      modules+=("$line")
    fi
  done < "$AI_MODULES_FILE"
  [[ ${#targets[@]} -eq 0 ]] && targets=("$DEFAULT_TARGET")
  echo "TARGETS='${targets[*]}'"
  echo "MODULES='${modules[*]}'"
  echo "SKILLS='${skills[*]}'"
}

git_commit_repo() {
  local msg="${1:-update modules}"
  cd "$AI_INST_DIR"
  git add -A
  if ! git diff --cached --quiet; then
    git commit -m "$msg"
  fi
  cd - > /dev/null
}

# Ensure entries exist in .gitignore (idempotent)
gitignore_ensure() {
  local gitignore=".gitignore"
  touch "$gitignore"
  for entry in "$@"; do
    grep -qxF "$entry" "$gitignore" 2>/dev/null || echo "$entry" >> "$gitignore"
  done
}

# Parse .ai-modules and populate TARGETS_ARR, MODULES_ARR, SKILLS_ARR
load_project_config() {
  eval "$(parse_ai_modules)"
  TARGETS_ARR=()
  MODULES_ARR=()
  SKILLS_ARR=()
  # shellcheck disable=SC2086
  [[ -n "${TARGETS:-}" ]] && read -ra TARGETS_ARR <<< "$TARGETS" || true
  # shellcheck disable=SC2086
  [[ -n "${MODULES:-}" ]] && read -ra MODULES_ARR <<< "$MODULES" || true
  # shellcheck disable=SC2086
  [[ -n "${SKILLS:-}" ]] && read -ra SKILLS_ARR <<< "$SKILLS" || true
}

# ─── repo commands ────────────────────────────────────────────────────────────

cmd_repo_init() {
  local remote="" tool_repo=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --remote) remote="$2"; shift 2 ;;
      --tool-repo) tool_repo="$2"; shift 2 ;;
      *) die "Unknown option: $1" ;;
    esac
  done

  if [[ -d "$AI_INST_DIR/.git" ]]; then
    die "Rules repo already exists at $AI_INST_DIR"
  fi

  mkdir -p "$MODULES_DIR"
  mkdir -p "$SKILLS_DIR"
  mkdir -p "$MIGRATIONS_DIR"
  cd "$AI_INST_DIR"
  git init

  # README
  cat > README.md << 'READMEEOF'
# AI Instructions

Personal repository of AI agent instruction modules.

Managed by [ai-inst](https://github.com/moonbreeze/ai-inst).

## Usage

```bash
ai-inst list          # list available modules
ai-inst new <name>    # create a new module
ai-inst push          # sync to remote
```
READMEEOF

  # Generate bootstrap.sh
  # Determine tool repo URL
  if [[ -z "$tool_repo" ]]; then
    # Try to detect from current ai-inst installation
    local script_path
    script_path="$(readlink -f "$(which ai-inst 2>/dev/null)" 2>/dev/null || true)"
    if [[ -n "$script_path" ]]; then
      local script_dir
      script_dir="$(dirname "$script_path")"
      if [[ -d "$script_dir/.git" ]]; then
        tool_repo="$(cd "$script_dir" && git remote get-url origin 2>/dev/null || true)"
      fi
    fi
  fi
  tool_repo="${tool_repo:-https://github.com/moonbreeze/ai-inst.git}"

  cat > bootstrap.sh << BSEOF
#!/usr/bin/env bash
set -euo pipefail

# Bootstrap script — installs ai-inst tool and sets up environment
# Generated by: ai-inst repo init

TOOL_REPO="$tool_repo"
TOOL_DIR="/tmp/ai-inst-install"

echo ":: Installing ai-inst tool..."
rm -rf "\$TOOL_DIR"
git clone "\$TOOL_REPO" "\$TOOL_DIR"
"\$TOOL_DIR/install.sh"
rm -rf "\$TOOL_DIR"

echo ":: Done! ai-inst is installed, rules repo is at: $AI_INST_DIR"
echo "   Run 'ai-inst list' to see available modules."
BSEOF
  chmod +x bootstrap.sh

  git add -A
  git commit -m "init rules repo"

  if [[ -n "$remote" ]]; then
    git remote add origin "$remote"
    info "Remote set to $remote"
    info "Run 'ai-inst push' to push to remote."
  fi

  cd - > /dev/null
  info "Rules repo initialized at $AI_INST_DIR"
}

cmd_repo_clone() {
  local url="${1:-}"
  [[ -z "$url" ]] && die "Usage: ai-inst repo clone <url>"
  [[ -d "$AI_INST_DIR" ]] && die "$AI_INST_DIR already exists"
  git clone "$url" "$AI_INST_DIR"
  info "Rules repo cloned to $AI_INST_DIR"
}

cmd_repo_sync() {
  ensure_repo
  cd "$AI_INST_DIR"
  git pull --rebase 2>/dev/null || git pull
  git push 2>/dev/null || info "Push failed (no remote or auth issue)"
  cd - > /dev/null
  info "Sync complete"
}

cmd_repo_path() {
  ensure_repo
  echo "$AI_INST_DIR"
}

cmd_repo() {
  local subcmd="${1:-}"
  shift || true
  case "$subcmd" in
    init)   cmd_repo_init "$@" ;;
    clone)  cmd_repo_clone "$@" ;;
    sync)   cmd_repo_sync "$@" ;;
    path)   cmd_repo_path "$@" ;;
    *)      die "Usage: ai-inst repo {init|clone|sync|path}" ;;
  esac
}

# ─── Module commands ──────────────────────────────────────────────────────────

cmd_list() {
  ensure_repo
  local project_modules=()
  if [[ -f "$AI_MODULES_FILE" ]]; then
    load_project_config
    project_modules=("${MODULES_ARR[@]+"${MODULES_ARR[@]}"}")
  fi

  for f in "$MODULES_DIR"/*.md; do
    [[ -f "$f" ]] || continue
    local name
    name="$(basename "$f" .md)"
    local marker=" "
    for pm in "${project_modules[@]+"${project_modules[@]}"}"; do
      if [[ "$pm" == "$name" ]]; then
        marker="*"
        break
      fi
    done
    echo " $marker $name"
  done
}

cmd_new() {
  ensure_repo
  local name="${1:-}"
  [[ -z "$name" ]] && die "Usage: ai-inst new <name>"
  local path
  path="$(module_path "$name")"
  [[ -f "$path" ]] && die "Module '$name' already exists"

  cat > "$path" << EOF
# $name

<!-- Module: $name -->
<!-- Add your instructions below -->

EOF

  if [[ -n "${EDITOR:-}" ]]; then
    "$EDITOR" "$path"
  fi
  git_commit_repo "add module: $name"
  info "Module '$name' created"
}

cmd_edit() {
  ensure_repo
  local name="${1:-}"
  [[ -z "$name" ]] && die "Usage: ai-inst edit <name>"
  module_exists "$name" || die "Module '$name' not found"
  local path
  path="$(module_path "$name")"

  if [[ -n "${EDITOR:-}" ]]; then
    "$EDITOR" "$path"
  else
    die "No \$EDITOR set"
  fi
  git_commit_repo "edit module: $name"
  info "Module '$name' updated"
}

cmd_show() {
  ensure_repo
  local name="${1:-}"
  [[ -z "$name" ]] && die "Usage: ai-inst show <name>"
  module_exists "$name" || die "Module '$name' not found"
  cat "$(module_path "$name")"
}

cmd_rm() {
  ensure_repo
  local name="${1:-}"
  [[ -z "$name" ]] && die "Usage: ai-inst rm <name>"
  module_exists "$name" || die "Module '$name' not found"
  rm "$(module_path "$name")"
  git_commit_repo "remove module: $name"
  info "Module '$name' removed"
}

# ─── Skill commands ───────────────────────────────────────────────────────────

cmd_skill_new() {
  ensure_repo
  local name="${1:-}"
  [[ -z "$name" ]] && die "Usage: ai-inst skill new <name>"
  skill_exists "$name" && die "Skill '$name' already exists"

  mkdir -p "$SKILLS_DIR/$name"
  cat > "$SKILLS_DIR/$name/SKILL.md" << EOF
---
name: $name
description:
---

# $name

<!-- Add skill instructions here -->
EOF

  if [[ -n "${EDITOR:-}" ]]; then
    "$EDITOR" "$SKILLS_DIR/$name/SKILL.md"
  fi
  git_commit_repo "add skill: $name"
  info "Skill '$name' created"
}

cmd_skill_list() {
  ensure_repo
  local project_skills=()
  if [[ -f "$AI_MODULES_FILE" ]]; then
    load_project_config
    project_skills=("${SKILLS_ARR[@]+"${SKILLS_ARR[@]}"}")
  fi

  for d in "$SKILLS_DIR"/*/; do
    [[ -d "$d" ]] || continue
    [[ -f "$d/SKILL.md" ]] || continue
    local name
    name="$(basename "$d")"
    local marker=" "
    for ps in "${project_skills[@]+"${project_skills[@]}"}"; do
      if [[ "$ps" == "$name" ]]; then
        marker="*"
        break
      fi
    done
    echo " $marker $name"
  done
}

cmd_skill_show() {
  ensure_repo
  local name="${1:-}"
  [[ -z "$name" ]] && die "Usage: ai-inst skill show <name>"
  skill_exists "$name" || die "Skill '$name' not found"
  cat "$SKILLS_DIR/$name/SKILL.md"
}

cmd_skill_edit() {
  ensure_repo
  local name="${1:-}"
  [[ -z "$name" ]] && die "Usage: ai-inst skill edit <name>"
  skill_exists "$name" || die "Skill '$name' not found"

  if [[ -n "${EDITOR:-}" ]]; then
    "$EDITOR" "$SKILLS_DIR/$name/SKILL.md"
  else
    die "No \$EDITOR set"
  fi
  git_commit_repo "edit skill: $name"
  info "Skill '$name' updated"
}

cmd_skill_rm() {
  ensure_repo
  local name="${1:-}"
  [[ -z "$name" ]] && die "Usage: ai-inst skill rm <name>"
  skill_exists "$name" || die "Skill '$name' not found"
  rm -rf "$SKILLS_DIR/$name"
  git_commit_repo "remove skill: $name"
  info "Skill '$name' removed"
}

cmd_skill() {
  local subcmd="${1:-}"
  shift || true
  case "$subcmd" in
    new)   cmd_skill_new "$@" ;;
    list)  cmd_skill_list "$@" ;;
    show)  cmd_skill_show "$@" ;;
    edit)  cmd_skill_edit "$@" ;;
    rm)    cmd_skill_rm "$@" ;;
    *)     die "Usage: ai-inst skill {new|list|show|edit|rm}" ;;
  esac
}

# ─── Push ──────────────────────────────────────────────────────────────────

cmd_push() {
  ensure_repo
  local msg="update modules"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -m) msg="$2"; shift 2 ;;
      *) die "Unknown option: $1" ;;
    esac
  done
  cd "$AI_INST_DIR"
  git add -A
  if ! git diff --cached --quiet; then
    git commit -m "$msg"
  fi
  git push
  cd - > /dev/null
  info "Pushed to remote"
}

# ─── Project commands ─────────────────────────────────────────────────────────

cmd_project_init() {
  if [[ ! -f "$AI_MODULES_FILE" ]]; then
    cat > "$AI_MODULES_FILE" << 'EOF'
# Modules for this project (one per line)
# targets: CLAUDE.md .cursorrules AGENTS.md
targets: CLAUDE.md

EOF
    info "Created $AI_MODULES_FILE"
  else
    info "$AI_MODULES_FILE already exists"
  fi

  if [[ ! -f "$LOCAL_INSTRUCTIONS" ]]; then
    cat > "$LOCAL_INSTRUCTIONS" << 'EOF'
# Project-specific instructions

<!-- Add project-specific instructions here. These will be appended after all modules. -->

EOF
    info "Created $LOCAL_INSTRUCTIONS"
  fi

  gitignore_ensure CLAUDE.md .cursorrules AGENTS.md
  info "Updated .gitignore"
}

cmd_project_add() {
  ensure_project
  ensure_repo
  [[ $# -eq 0 ]] && die "Usage: ai-inst project add <module...>"

  for name in "$@"; do
    module_exists "$name" || die "Module '$name' not found in rules repo"
    if grep -qxF "$name" "$AI_MODULES_FILE" 2>/dev/null; then
      info "Module '$name' already in project"
    else
      echo "$name" >> "$AI_MODULES_FILE"
      info "Added '$name'"
    fi
  done
}

cmd_project_rm() {
  ensure_project
  [[ $# -eq 0 ]] && die "Usage: ai-inst project rm <module...>"

  for name in "$@"; do
    if grep -qxF "$name" "$AI_MODULES_FILE" 2>/dev/null; then
      local tmpfile
      tmpfile="$(mktemp)"
      grep -vxF "$name" "$AI_MODULES_FILE" > "$tmpfile"
      mv "$tmpfile" "$AI_MODULES_FILE"
      info "Removed '$name'"
    else
      info "Module '$name' not in project"
    fi
  done
}

cmd_project_add_skill() {
  ensure_project
  ensure_repo
  [[ $# -eq 0 ]] && die "Usage: ai-inst project add-skill <skill...>"

  for name in "$@"; do
    skill_exists "$name" || die "Skill '$name' not found in rules repo"

    load_project_config

    local already=0
    for s in "${SKILLS_ARR[@]+"${SKILLS_ARR[@]}"}"; do
      [[ "$s" == "$name" ]] && already=1 && break
    done

    if [[ $already -eq 1 ]]; then
      info "Skill '$name' already in project"
    else
      if grep -q '^\[skills\]' "$AI_MODULES_FILE" 2>/dev/null; then
        echo "$name" >> "$AI_MODULES_FILE"
      else
        printf '\n[skills]\n%s\n' "$name" >> "$AI_MODULES_FILE"
      fi
      info "Added skill '$name'"
    fi
  done
}

cmd_project_rm_skill() {
  ensure_project
  [[ $# -eq 0 ]] && die "Usage: ai-inst project rm-skill <skill...>"

  for name in "$@"; do
    load_project_config

    local found=0
    for s in "${SKILLS_ARR[@]+"${SKILLS_ARR[@]}"}"; do
      [[ "$s" == "$name" ]] && found=1 && break
    done

    if [[ $found -eq 1 ]]; then
      local tmpfile
      tmpfile="$(mktemp)"
      grep -vxF "$name" "$AI_MODULES_FILE" > "$tmpfile"
      mv "$tmpfile" "$AI_MODULES_FILE"
      info "Removed skill '$name'"
    else
      info "Skill '$name' not in project"
    fi
  done
}

cmd_project_edit() {
  [[ -f "$LOCAL_INSTRUCTIONS" ]] || die "No $LOCAL_INSTRUCTIONS found. Run: ai-inst project init"
  if [[ -n "${EDITOR:-}" ]]; then
    "$EDITOR" "$LOCAL_INSTRUCTIONS"
  else
    die "No \$EDITOR set"
  fi
  info "Local instructions updated"
}

cmd_project_status() {
  ensure_project
  echo "Project: $(pwd)"
  echo ""

  load_project_config

  echo "Targets: ${TARGETS_ARR[*]}"
  echo ""
  echo "Modules:"
  for m in "${MODULES_ARR[@]+"${MODULES_ARR[@]}"}"; do
    [[ -z "$m" ]] && continue
    if module_exists "$m"; then
      echo "  + $m"
    else
      echo "  ! $m (not found)"
    fi
  done

  if [[ ${#SKILLS_ARR[@]} -gt 0 ]]; then
    echo ""
    echo "Skills:"
    for s in "${SKILLS_ARR[@]}"; do
      [[ -z "$s" ]] && continue
      if skill_exists "$s"; then
        echo "  + $s"
      else
        echo "  ! $s (not found)"
      fi
    done
  fi

  echo ""
  echo "Built files:"
  for t in "${TARGETS_ARR[@]}"; do
    if [[ -f "$t" ]]; then
      echo "  + $t ($(wc -l < "$t") lines)"
    else
      echo "  - $t (not built)"
    fi
  done

  if [[ -f "$LOCAL_INSTRUCTIONS" ]]; then
    echo ""
    echo "Local instructions: $LOCAL_INSTRUCTIONS"
  fi
}

cmd_project_targets() {
  ensure_project
  [[ $# -eq 0 ]] && die "Usage: ai-inst project targets <file...>"

  local targets_line="targets: $*"
  if grep -q '^targets:' "$AI_MODULES_FILE"; then
    local tmpfile
    tmpfile="$(mktemp)"
    sed "s|^targets:.*|$targets_line|" "$AI_MODULES_FILE" > "$tmpfile"
    mv "$tmpfile" "$AI_MODULES_FILE"
  else
    local tmpfile
    tmpfile="$(mktemp)"
    echo "$targets_line" > "$tmpfile"
    cat "$AI_MODULES_FILE" >> "$tmpfile"
    mv "$tmpfile" "$AI_MODULES_FILE"
  fi
  info "Targets set to: $*"

  gitignore_ensure "$@"
}

cmd_project() {
  local subcmd="${1:-}"
  shift || true
  case "$subcmd" in
    init)      cmd_project_init "$@" ;;
    add)       cmd_project_add "$@" ;;
    rm)        cmd_project_rm "$@" ;;
    edit)      cmd_project_edit "$@" ;;
    status)    cmd_project_status "$@" ;;
    targets)   cmd_project_targets "$@" ;;
    add-skill) cmd_project_add_skill "$@" ;;
    rm-skill)  cmd_project_rm_skill "$@" ;;
    *)         die "Usage: ai-inst project {init|add|rm|edit|status|targets|add-skill|rm-skill}" ;;
  esac
}

# ─── Migrations ───────────────────────────────────────────────────────────────

# Parse a migration YAML file → sets MIGRATION_ID, MIGRATION_DESC, MIGRATION_RULES[]
# Each rule is encoded as "when_key=when_val|then_key1=then_val1|then_key2=then_val2"
parse_migration() {
  local file="$1"
  MIGRATION_ID=""
  MIGRATION_DESC=""
  MIGRATION_RULES=()

  local section="" when_part="" then_parts=""
  while IFS= read -r line; do
    # strip comments and trailing whitespace
    line="${line%%#*}"
    [[ -z "${line// /}" ]] && continue

    if [[ "$line" =~ ^id:\ *\"?([^\"]*)\"? ]]; then
      MIGRATION_ID="${BASH_REMATCH[1]}"
      continue
    fi
    if [[ "$line" =~ ^description:\ *\"?([^\"]*)\"? ]]; then
      MIGRATION_DESC="${BASH_REMATCH[1]}"
      continue
    fi
    if [[ "$line" == "rules:" ]]; then
      section="rules"
      continue
    fi

    if [[ "$section" == "rules" ]]; then
      # new rule entry: "  - when:"
      if [[ "$line" =~ ^[[:space:]]*-[[:space:]]*when: ]]; then
        # save previous rule if any
        if [[ -n "$when_part" ]]; then
          MIGRATION_RULES+=("${when_part}${then_parts}")
        fi
        when_part=""
        then_parts=""
        section="when"
        continue
      fi
    fi

    if [[ "$section" == "when" ]]; then
      if [[ "$line" =~ ^[[:space:]]*then: ]]; then
        section="then"
        continue
      fi
      # parse condition: "      has_module: typescript"
      local trimmed
      trimmed="$(echo "$line" | xargs)"
      local key="${trimmed%%:*}"
      local val="${trimmed#*: }"
      when_part="${key}=${val}"
    fi

    if [[ "$section" == "then" ]]; then
      # next rule or end
      if [[ "$line" =~ ^[[:space:]]*-[[:space:]]*when: ]]; then
        MIGRATION_RULES+=("${when_part}${then_parts}")
        when_part=""
        then_parts=""
        section="when"
        continue
      fi
      local trimmed
      trimmed="$(echo "$line" | xargs)"
      local key="${trimmed%%:*}"
      local val="${trimmed#*: }"
      then_parts+="|${key}=${val}"
    fi
  done < "$file"

  # save last rule
  if [[ -n "$when_part" ]]; then
    MIGRATION_RULES+=("${when_part}${then_parts}")
  fi
}

# Check if migration ID has been applied
migration_is_applied() {
  local id="$1"
  [[ -f "$AI_MIGRATIONS_STATE" ]] && grep -qxF "$id" "$AI_MIGRATIONS_STATE" 2>/dev/null
}

# Check a when-condition against current project config
migration_check_condition() {
  local cond="$1"
  local key="${cond%%=*}"
  local val="${cond#*=}"

  case "$key" in
    has_module)
      for m in "${MODULES_ARR[@]+"${MODULES_ARR[@]}"}"; do
        [[ "$m" == "$val" ]] && return 0
      done
      return 1
      ;;
    has_skill)
      for s in "${SKILLS_ARR[@]+"${SKILLS_ARR[@]}"}"; do
        [[ "$s" == "$val" ]] && return 0
      done
      return 1
      ;;
    not_has_skill)
      for s in "${SKILLS_ARR[@]+"${SKILLS_ARR[@]}"}"; do
        [[ "$s" == "$val" ]] && return 1
      done
      return 0
      ;;
    not_has_module)
      for m in "${MODULES_ARR[@]+"${MODULES_ARR[@]}"}"; do
        [[ "$m" == "$val" ]] && return 1
      done
      return 0
      ;;
    *)
      echo "warning: unknown condition '$key' in migration" >&2
      return 1
      ;;
  esac
}

# Apply a then-action to the project
migration_apply_action() {
  local action="$1"
  local key="${action%%=*}"
  local val="${action#*=}"

  case "$key" in
    add_module)
      # Only add if not already present
      local found=0
      for m in "${MODULES_ARR[@]+"${MODULES_ARR[@]}"}"; do
        [[ "$m" == "$val" ]] && found=1 && break
      done
      if [[ $found -eq 0 ]]; then
        # Add before [skills] section if it exists, otherwise append
        if grep -q '^\[skills\]' "$AI_MODULES_FILE" 2>/dev/null; then
          local tmpfile
          tmpfile="$(mktemp)"
          sed "/^\[skills\]/i $val" "$AI_MODULES_FILE" > "$tmpfile"
          mv "$tmpfile" "$AI_MODULES_FILE"
        else
          echo "$val" >> "$AI_MODULES_FILE"
        fi
        info "  + add module: $val"
      fi
      ;;
    remove_module)
      if grep -qxF "$val" "$AI_MODULES_FILE" 2>/dev/null; then
        local tmpfile
        tmpfile="$(mktemp)"
        grep -vxF "$val" "$AI_MODULES_FILE" > "$tmpfile"
        mv "$tmpfile" "$AI_MODULES_FILE"
        info "  - remove module: $val"
      fi
      ;;
    add_skill)
      # Check if already present
      load_project_config
      local found=0
      for s in "${SKILLS_ARR[@]+"${SKILLS_ARR[@]}"}"; do
        [[ "$s" == "$val" ]] && found=1 && break
      done
      if [[ $found -eq 0 ]]; then
        if grep -q '^\[skills\]' "$AI_MODULES_FILE" 2>/dev/null; then
          echo "$val" >> "$AI_MODULES_FILE"
        else
          printf '\n[skills]\n%s\n' "$val" >> "$AI_MODULES_FILE"
        fi
        info "  + add skill: $val"
      fi
      ;;
    remove_skill)
      if grep -qxF "$val" "$AI_MODULES_FILE" 2>/dev/null; then
        local tmpfile
        tmpfile="$(mktemp)"
        grep -vxF "$val" "$AI_MODULES_FILE" > "$tmpfile"
        mv "$tmpfile" "$AI_MODULES_FILE"
        info "  - remove skill: $val"
      fi
      ;;
    *)
      echo "warning: unknown action '$key' in migration" >&2
      ;;
  esac
}

# Apply a single migration file
apply_migration() {
  local file="$1"
  parse_migration "$file"

  [[ -z "$MIGRATION_ID" ]] && { echo "warning: migration without id, skipping: $file" >&2; return; }

  if migration_is_applied "$MIGRATION_ID"; then
    return
  fi

  load_project_config

  local applied_any=0
  for rule in "${MIGRATION_RULES[@]+"${MIGRATION_RULES[@]}"}"; do
    # Split: first part is condition, rest are actions
    local cond="${rule%%|*}"
    local actions="${rule#*|}"

    if migration_check_condition "$cond"; then
      # Apply each action
      while [[ -n "$actions" ]]; do
        local action
        if [[ "$actions" == *"|"* ]]; then
          action="${actions%%|*}"
          actions="${actions#*|}"
        else
          action="$actions"
          actions=""
        fi
        [[ -z "$action" ]] && continue
        migration_apply_action "$action"
        applied_any=1
      done
      # Reload config after actions
      load_project_config
    fi
  done

  # Mark as applied
  echo "$MIGRATION_ID" >> "$AI_MIGRATIONS_STATE"

  if [[ $applied_any -eq 1 ]]; then
    info "Applied migration: $MIGRATION_ID"
  fi
}

cmd_migrate() {
  ensure_project
  ensure_repo

  local show_status=0
  local create_slug=""
  local create_desc=""
  local -a create_rules=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --status) show_status=1; shift ;;
      --create) create_slug="$2"; shift 2 ;;
      --description) create_desc="$2"; shift 2 ;;
      --rule) create_rules+=("$2"); shift 2 ;;
      *) die "Unknown option: $1" ;;
    esac
  done

  if [[ -n "$create_slug" ]]; then
    mkdir -p "$MIGRATIONS_DIR"
    local timestamp
    timestamp="$(date +%Y-%m-%d)"
    local filename="${timestamp}-${create_slug}.yml"
    local filepath="$MIGRATIONS_DIR/$filename"
    [[ -f "$filepath" ]] && die "Migration file already exists: $filename"

    local mid="${timestamp}-${create_slug}"

    if [[ ${#create_rules[@]} -gt 0 ]]; then
      # Build YAML from parameters
      {
        echo "id: \"$mid\""
        echo "description: \"$create_desc\""
        echo "rules:"
        for rule in "${create_rules[@]}"; do
          # Format: "when_key:when_val->then_key1:then_val1,then_key2:then_val2"
          local when_part="${rule%%->*}"
          local then_part="${rule#*->}"
          local when_key="${when_part%%:*}"
          local when_val="${when_part#*:}"
          echo "  - when:"
          echo "      ${when_key}: ${when_val}"
          echo "    then:"
          IFS=',' read -ra actions <<< "$then_part"
          for action in "${actions[@]}"; do
            local act_key="${action%%:*}"
            local act_val="${action#*:}"
            echo "      ${act_key}: ${act_val}"
          done
        done
      } > "$filepath"
    else
      # Template fallback
      cat > "$filepath" << EOF
id: "$mid"
description: "$create_desc"
rules:
  - when:
      has_module: example
    then:
      add_skill: example
EOF
      if [[ -n "${EDITOR:-}" ]]; then
        "$EDITOR" "$filepath"
      fi
    fi

    git_commit_repo "add migration: $create_slug"
    info "Migration created: $filename"
    return
  fi

  if [[ ! -d "$MIGRATIONS_DIR" ]]; then
    if [[ $show_status -eq 1 ]]; then info "No migrations directory found"; fi
    return 0
  fi

  local migration_files=()
  for f in "$MIGRATIONS_DIR"/*.yml; do
    [[ -f "$f" ]] || continue
    migration_files+=("$f")
  done

  if [[ ${#migration_files[@]} -eq 0 ]]; then
    if [[ $show_status -eq 1 ]]; then info "No migrations found"; fi
    return 0
  fi

  # Sort by filename (timestamp prefix ensures order)
  IFS=$'\n' migration_files=($(sort <<< "${migration_files[*]}")); unset IFS

  if [[ $show_status -eq 1 ]]; then
    local pending=0
    for f in "${migration_files[@]}"; do
      parse_migration "$f"
      if [[ -z "$MIGRATION_ID" ]]; then
        continue
      fi
      if migration_is_applied "$MIGRATION_ID"; then
        echo "  ✓ $MIGRATION_ID — ${MIGRATION_DESC:-no description}"
      else
        echo "  · $MIGRATION_ID — ${MIGRATION_DESC:-no description}"
        pending=$((pending + 1))
      fi
    done
    info "$pending pending migration(s)"
    return
  fi

  for f in "${migration_files[@]}"; do
    apply_migration "$f"
  done

  gitignore_ensure "$AI_MIGRATIONS_STATE"
}

# ─── Build ────────────────────────────────────────────────────────────────────

cmd_build() {
  ensure_project
  ensure_repo

  local filter_target=""
  local no_migrate=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --target) filter_target="$2"; shift 2 ;;
      --no-migrate) no_migrate=1; shift ;;
      *) die "Unknown option: $1" ;;
    esac
  done

  # Run migrations before build unless --no-migrate
  if [[ $no_migrate -eq 0 && -d "$MIGRATIONS_DIR" ]]; then
    cmd_migrate
  fi

  load_project_config

  # Build content
  local content=""
  content="<!-- AUTO-GENERATED by ai-inst — do not edit manually -->"$'\n\n'

  for m in "${MODULES_ARR[@]+"${MODULES_ARR[@]}"}"; do
    [[ -z "$m" ]] && continue
    local mpath
    mpath="$(module_path "$m")"
    if [[ -f "$mpath" ]]; then
      content+="$(cat "$mpath")"$'\n\n'
    else
      echo "warning: module '$m' not found, skipping" >&2
    fi
  done

  # Generate skills index
  if [[ ${#SKILLS_ARR[@]} -gt 0 ]]; then
    local skills_index
    skills_index="## Available skills"$'\n\n'
    skills_index+="The following skills are available on demand:"$'\n'
    for s in "${SKILLS_ARR[@]}"; do
      [[ -z "$s" ]] && continue
      local desc
      desc="$(skill_description "$s" 2>/dev/null || true)"
      if [[ -n "$desc" ]]; then
        skills_index+="- \`$s\` — $desc"$'\n'
      else
        skills_index+="- \`$s\`"$'\n'
      fi
    done
    content+="$skills_index"$'\n'
  fi

  if [[ -f "$LOCAL_INSTRUCTIONS" ]]; then
    local local_content
    local_content="$(cat "$LOCAL_INSTRUCTIONS")"
    if [[ -n "$local_content" ]]; then
      content+="$local_content"$'\n'
    fi
  fi

  # Write to targets
  for t in "${TARGETS_ARR[@]}"; do
    if [[ -n "$filter_target" && "$t" != "$filter_target" ]]; then
      continue
    fi
    echo "$content" > "$t"
    info "Built $t ($(wc -l < "$t") lines)"
  done

  # Copy skills to platform directories
  if [[ ${#SKILLS_ARR[@]} -gt 0 ]]; then
    # Clean old skills dirs
    rm -rf ".claude/skills" ".agents/skills"

    local copied=0
    for s in "${SKILLS_ARR[@]}"; do
      [[ -z "$s" ]] && continue
      if skill_exists "$s"; then
        mkdir -p ".claude/skills/$s" ".agents/skills/$s"
        cp -r "$SKILLS_DIR/$s/." ".claude/skills/$s/"
        cp -r "$SKILLS_DIR/$s/." ".agents/skills/$s/"
        copied=$((copied + 1))
      else
        echo "warning: skill '$s' not found, skipping" >&2
      fi
    done

    [[ $copied -gt 0 ]] && info "Copied $copied skill(s) to .claude/skills/ and .agents/skills/"

    gitignore_ensure ".claude/skills/" ".agents/skills/"
  fi
}

# ─── Hooks ────────────────────────────────────────────────────────────────────

cmd_hook_install() {
  [[ -d ".git" ]] || die "Not a git repository"
  ensure_project

  local hooks_dir=".git/hooks"
  local hook_content='#!/usr/bin/env bash
# ai-inst auto-build hook
if command -v ai-inst &>/dev/null && [[ -f ".ai-modules" ]]; then
  ai-inst build
fi'

  for hook in post-checkout post-merge; do
    local hook_file="$hooks_dir/$hook"
    if [[ -f "$hook_file" ]]; then
      if grep -q "ai-inst" "$hook_file"; then
        info "Hook $hook already installed"
        continue
      fi
      echo "" >> "$hook_file"
      echo "$hook_content" >> "$hook_file"
    else
      echo "$hook_content" > "$hook_file"
    fi
    chmod +x "$hook_file"
    info "Installed $hook hook"
  done
}

cmd_hook_remove() {
  [[ -d ".git" ]] || die "Not a git repository"
  local hooks_dir=".git/hooks"

  for hook in post-checkout post-merge; do
    local hook_file="$hooks_dir/$hook"
    if [[ -f "$hook_file" ]] && grep -q "ai-inst" "$hook_file"; then
      local tmpfile
      tmpfile="$(mktemp)"
      sed '/# ai-inst auto-build hook/,/^fi$/d' "$hook_file" > "$tmpfile"
      # Remove if empty (only shebang left)
      if [[ $(wc -l < "$tmpfile") -le 1 ]]; then
        rm "$hook_file"
      else
        mv "$tmpfile" "$hook_file"
      fi
      info "Removed $hook hook"
    fi
  done
}

cmd_hook() {
  local subcmd="${1:-}"
  shift || true
  case "$subcmd" in
    install) cmd_hook_install "$@" ;;
    remove)  cmd_hook_remove "$@" ;;
    *)       die "Usage: ai-inst hook {install|remove}" ;;
  esac
}

# ─── MCP ───────────────────────────────────────────────────────────────────

# Parse --claude/--codex/--global options, sets MCP_SCOPE and MCP_TARGET
mcp_parse_opts() {
  MCP_SCOPE="project"
  MCP_TARGET="claude"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --global) MCP_SCOPE="global"; shift ;;
      --claude) MCP_TARGET="claude"; shift ;;
      --codex)  MCP_TARGET="codex"; shift ;;
      *) return 1 ;;
    esac
  done
}

cmd_mcp_install() {
  mcp_parse_opts "$@" || die "Unknown option. Usage: ai-inst mcp install [--claude|--codex] [--global]"
  local scope="$MCP_SCOPE" target="$MCP_TARGET"

  # Determine MCP server path
  local script_path
  script_path="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || readlink -f "$(which ai-inst)" 2>/dev/null || true)"
  local mcp_dir=""
  if [[ -n "$script_path" ]]; then
    mcp_dir="$(dirname "$script_path")/mcp-server"
  fi
  [[ -d "$mcp_dir" ]] || die "MCP server directory not found at $mcp_dir"
  [[ -f "$mcp_dir/src/index.ts" ]] || die "MCP server source not found"

  if [[ "$target" == "claude" ]]; then
    if [[ "$scope" == "global" ]]; then
      command -v claude &>/dev/null || die "'claude' CLI not found — required for --global"
      local output
      if output="$(claude mcp add -s user ai-inst -- npx tsx "$mcp_dir/src/index.ts" 2>&1)"; then
        info "MCP server added globally (claude mcp, scope: user)"
      else
        if echo "$output" | grep -qi "already"; then
          info "MCP server 'ai-inst' already configured globally"
        else
          die "Failed to add MCP server globally: $output"
        fi
      fi
      return
    fi

    local mcp_file=".mcp.json"

    local server_json
    server_json=$(cat <<JSONEOF
{
  "command": "npx",
  "args": ["tsx", "$mcp_dir/src/index.ts"]
}
JSONEOF
)

    if [[ -f "$mcp_file" ]]; then
      if grep -q '"ai-inst"' "$mcp_file" 2>/dev/null; then
        info "MCP server 'ai-inst' already configured in $mcp_file"
        return
      fi
      local tmpfile
      tmpfile="$(mktemp)"
      if command -v node &>/dev/null; then
        node -e "
          const fs = require('fs');
          const cfg = JSON.parse(fs.readFileSync('$mcp_file', 'utf-8'));
          const servers = cfg.mcpServers || {};
          servers['ai-inst'] = $server_json;
          cfg.mcpServers = servers;
          fs.writeFileSync('$tmpfile', JSON.stringify(cfg, null, 2) + '\n');
        "
      elif command -v python3 &>/dev/null; then
        python3 -c "
import json
with open('$mcp_file') as f:
    cfg = json.load(f)
cfg.setdefault('mcpServers', {})['ai-inst'] = json.loads('''$server_json''')
with open('$tmpfile', 'w') as f:
    json.dump(cfg, f, indent=2)
    f.write('\n')
"
      else
        die "node or python3 required to modify $mcp_file"
      fi
      mv "$tmpfile" "$mcp_file"
    else
      cat > "$mcp_file" << SEOF
{
  "mcpServers": {
    "ai-inst": $server_json
  }
}
SEOF
    fi

    info "MCP server added to $mcp_file"
    return
  fi

  # target == codex
  local codex_config codex_scope_desc
  if [[ "$scope" == "global" ]]; then
    codex_config="$HOME/.codex/config.toml"
    codex_scope_desc="global"
  else
    codex_config=".codex/config.toml"
    codex_scope_desc="project"
  fi

  local codex_dir
  codex_dir="$(dirname "$codex_config")"
  mkdir -p "$codex_dir"

  if [[ -f "$codex_config" ]] && grep -q '^\[mcp_servers\.ai-inst\]' "$codex_config" 2>/dev/null; then
    info "MCP server 'ai-inst' already configured in $codex_config"
    return
  fi

  # ensure trailing newline
  if [[ -f "$codex_config" ]] && [[ $(tail -c 1 "$codex_config" 2>/dev/null | wc -l) -eq 0 ]]; then
    echo "" >> "$codex_config"
  fi

  cat >> "$codex_config" << TOML

[mcp_servers.ai-inst]
command = "npx"
args = ["tsx", "$mcp_dir/src/index.ts"]
TOML

  info "MCP server added to $codex_config ($codex_scope_desc)"
}

cmd_mcp_remove() {
  mcp_parse_opts "$@" || die "Unknown option. Usage: ai-inst mcp remove [--claude|--codex] [--global]"
  local scope="$MCP_SCOPE" target="$MCP_TARGET"

  if [[ "$target" == "claude" ]]; then
    if [[ "$scope" == "global" ]]; then
      command -v claude &>/dev/null || die "'claude' CLI not found — required for --global"
      local output
      if output="$(claude mcp remove -s user ai-inst 2>&1)"; then
        info "MCP server removed globally"
      else
        info "MCP server 'ai-inst' not found globally"
      fi
      return
    fi

    local mcp_file=".mcp.json"

    [[ -f "$mcp_file" ]] || die "$mcp_file not found"

    if ! grep -q '"ai-inst"' "$mcp_file" 2>/dev/null; then
      info "MCP server 'ai-inst' not found in $mcp_file"
      return
    fi

    local tmpfile
    tmpfile="$(mktemp)"
    if command -v node &>/dev/null; then
      node -e "
        const fs = require('fs');
        const cfg = JSON.parse(fs.readFileSync('$mcp_file', 'utf-8'));
        if (cfg.mcpServers) delete cfg.mcpServers['ai-inst'];
        fs.writeFileSync('$tmpfile', JSON.stringify(cfg, null, 2) + '\n');
      "
    elif command -v python3 &>/dev/null; then
      python3 -c "
import json
with open('$mcp_file') as f:
    cfg = json.load(f)
cfg.get('mcpServers', {}).pop('ai-inst', None)
with open('$tmpfile', 'w') as f:
    json.dump(cfg, f, indent=2)
    f.write('\n')
"
    else
      die "node or python3 required to modify $mcp_file"
    fi
    mv "$tmpfile" "$mcp_file"
    info "MCP server removed from $mcp_file"
    return
  fi

  # target == codex
  local codex_config
  if [[ "$scope" == "global" ]]; then
    codex_config="$HOME/.codex/config.toml"
  else
    codex_config=".codex/config.toml"
  fi

  [[ -f "$codex_config" ]] || die "$codex_config not found"

  if ! grep -q '^\[mcp_servers\.ai-inst\]' "$codex_config" 2>/dev/null; then
    info "MCP server 'ai-inst' not found in $codex_config"
    return
  fi

  local tmpfile
  tmpfile="$(mktemp)"
  awk '
    BEGIN {skip=0}
    /^\[mcp_servers\.ai-inst\]/{skip=1; next}
    skip && /^\[/{skip=0}
    !skip {print}
  ' "$codex_config" > "$tmpfile"
  mv "$tmpfile" "$codex_config"
  info "MCP server removed from $codex_config"
}

cmd_mcp_status() {
  mcp_parse_opts "$@" || die "Unknown option. Usage: ai-inst mcp status [--claude|--codex]"
  local target="$MCP_TARGET"

  if [[ "$target" == "claude" ]]; then
    local mcp_file=".mcp.json"
    local global_settings="$HOME/.claude/settings.local.json"

    echo "MCP server status (Claude Code):"
    echo ""
    if [[ -f "$global_settings" ]] && grep -q '"ai-inst"' "$global_settings" 2>/dev/null; then
      echo "  Global:  installed (~/.claude/settings.local.json)"
    else
      echo "  Global:  not installed"
    fi
    if [[ -f "$mcp_file" ]] && grep -q '"ai-inst"' "$mcp_file" 2>/dev/null; then
      echo "  Project: installed ($mcp_file)"
    else
      echo "  Project: not installed"
    fi
    return
  fi

  # target == codex
  local codex_global="$HOME/.codex/config.toml"
  local codex_project=".codex/config.toml"

  echo "MCP server status (Codex):"
  echo ""
  if [[ -f "$codex_global" ]] && grep -q '^\[mcp_servers\.ai-inst\]' "$codex_global" 2>/dev/null; then
    echo "  Global:  installed ($codex_global)"
  else
    echo "  Global:  not installed"
  fi
  if [[ -f "$codex_project" ]] && grep -q '^\[mcp_servers\.ai-inst\]' "$codex_project" 2>/dev/null; then
    echo "  Project: installed ($codex_project)"
  else
    echo "  Project: not installed"
  fi
}

cmd_mcp() {
  local subcmd="${1:-}"
  shift || true
  case "$subcmd" in
    install) cmd_mcp_install "$@" ;;
    remove)  cmd_mcp_remove "$@" ;;
    status)  cmd_mcp_status "$@" ;;
    *)       die "Usage: ai-inst mcp {install|remove|status} [--claude|--codex] [--global]" ;;
  esac
}

# ─── Main ─────────────────────────────────────────────────────────────────────

cmd_help() {
  cat << EOF
ai-inst — modular AI agent instruction manager

Usage: ai-inst <command> [args]

Repository:
  repo init [--remote <url>] [--tool-repo <url>]   Initialize rules repo
  repo clone <url>                                   Clone rules repo
  repo sync                                          Pull + push
  repo path                                          Print repo path

Modules:
  list                  List modules (* = active in project)
  new <name>            Create module
  edit <name>           Edit module
  show <name>           Show module content
  rm <name>             Delete module
  push [-m "msg"]       Commit & push rules repo

Skills:
  skill list                     List skills (* = active in project)
  skill new <name>               Create skill
  skill edit <name>              Edit skill
  skill show <name>              Show skill content
  skill rm <name>                Delete skill

Project:
  project init                    Create .ai-modules + instructions.local.md
  project add <mod...>            Add modules to project
  project rm <mod...>             Remove modules from project
  project add-skill <skill...>    Add skills to project
  project rm-skill <skill...>     Remove skills from project
  project edit                    Edit local instructions
  project status                  Show project status
  project targets <file...>       Set target files

Build:
  build [--target <file>] [--no-migrate]   Build instruction files

Migrations:
  Migrations auto-update .ai-modules when modules are renamed, split,
  or extracted into skills. They are YAML files in the rules repo
  (migrations/*.yml) with when/then rules. Applied automatically on build.

  migrate                          Apply pending migrations to .ai-modules
  migrate --status                 List all migrations and their applied/pending state
  migrate --create <slug>          Create a new migration (template or with --rule/--description)
    [--description "..."]           Migration description
    [--rule "when_key:val->act:val,act:val"]  Add rule (repeatable)

Hooks:
  hook install                    Install git hooks for auto-build
  hook remove                     Remove hooks

MCP:
  mcp install [--claude|--codex] [--global]  Add MCP server for Claude Code or Codex
  mcp remove  [--claude|--codex] [--global]  Remove MCP server for Claude Code or Codex
  mcp status  [--claude|--codex]              Show MCP installation status

Environment:
  AI_INST_DIR    Path to rules repo (default: ~/.ai-instructions)

Version: $VERSION
EOF
}

main() {
  local cmd="${1:-help}"
  shift || true
  case "$cmd" in
    repo)    cmd_repo "$@" ;;
    list)    cmd_list "$@" ;;
    new)     cmd_new "$@" ;;
    edit)    cmd_edit "$@" ;;
    show)    cmd_show "$@" ;;
    rm)      cmd_rm "$@" ;;
    push)    cmd_push "$@" ;;
    skill)   cmd_skill "$@" ;;
    project) cmd_project "$@" ;;
    build)   cmd_build "$@" ;;
    migrate) cmd_migrate "$@" ;;
    hook)    cmd_hook "$@" ;;
    mcp)     cmd_mcp "$@" ;;
    help|--help|-h) cmd_help ;;
    version|--version|-v) echo "ai-inst $VERSION" ;;
    *)       die "Unknown command: $cmd. Run 'ai-inst help' for usage." ;;
  esac
}

main "$@"
